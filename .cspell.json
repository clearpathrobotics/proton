{
  "ignorePaths": [
    ".gitignore",
    ".ruff.toml",
    "**/node_modules/**",
    "**/vscode-extension/**",
    ".git/*/**",
    ".vscode",
    "**/build/**",
    ".clang-format",
    ".github/workflows/**",
    "*.jinja",
    "core/src/generated/**",
    "core/include/proton/generated/**"
  ],
  "import": [
    "@cspell/dict-en-ca/cspell-ext.json"
  ],
  "language": "en-CA,en",
  "languageSettings": [
    {
      "ignoreRegExpList": [
        "pathname"
      ],
      "languageId": "cmake",
      "dictionaries": [
        "cpp"
      ]
    }
  ],
  "patterns": [
    {
      "name": "pathname",
      "pattern": "(\\.*[\\.\\w-]+)?(\\/(\\.*[\\.\\w-]+)?)"
    }
  ],
  "version": "0.2",
