  "ignorePaths": [
    ".gitignore",
    ".ruff.toml",
    "**/node_modules/**",
    "**/vscode-extension/**",
    ".git/*/**",
    ".vscode",
    "**/build/**"
  ],
  "import": [
    "@cspell/dict-en-ca/cspell-ext.json"
  ],
  "language": "en-CA,en",
  "languageSettings": [
    {
      "ignoreRegExpList": [
        "pathname"
