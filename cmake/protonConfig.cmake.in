@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Find dependencies that were enabled at build time
if(@PROTON_INSTALLED_WITH_JSON_PARSER@)
  find_dependency(nlohmann_json REQUIRED)
endif()

if(@PROTON_INSTALLED_WITH_YAML_PARSER@)
  find_dependency(yaml-cpp REQUIRED)
endif()

# Include the targets file
include("${CMAKE_CURRENT_LIST_DIR}/ProtonTargets.cmake")

# Include proton helper functions
include("${CMAKE_CURRENT_LIST_DIR}/protonCoreGenerator.cmake")

set(PROTONC_GENERATOR "@PROTONC_GENERATOR@")
