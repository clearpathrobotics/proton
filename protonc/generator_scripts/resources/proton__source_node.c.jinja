// Bundle Decode Function

proton_status_e proton_bundle_decode(proton_buffer_t buffer, proton_producer_t producer, uint32_t * id, size_t length)
{
  // Check that buffer is not NULL
  if (buffer.data == NULL || id == NULL)
  {
    return PROTON_NULL_PTR_ERROR;
  }

  proton_status_e status;
  proton_bundle_handle_t * handle;

  // Decode bundle ID
  status = proton_decode_id(buffer, id);
  if (status != PROTON_OK)
  {
    return status;
  }

  switch (*id)
  {
    case PROTON__BUNDLE__LOG:
    {
      handle = &_log_bundle_handle;
      break;
    }

    case PROTON__BUNDLE__STATUS:
    {
      handle = &_status_bundle_handle;
      break;
    }

    case PROTON__BUNDLE__POWER:
    {
      handle = &_power_bundle_handle;
      break;
    }

    case PROTON__BUNDLE__EMERGENCY_STOP:
    {
      handle = &_emergency_stop_bundle_handle;
      break;
    }

    case PROTON__BUNDLE__TEMPERATURE:
    {
      handle = &_temperature_bundle_handle;
      break;
    }

    case PROTON__BUNDLE__STOP_STATUS:
    {
      handle = &_stop_status_bundle_handle;
      break;
    }

    case PROTON__BUNDLE__PINOUT_STATE:
    {
      handle = &_pinout_state_bundle_handle;
      break;
    }

    case PROTON__BUNDLE__ALERTS:
    {
      handle = &_alerts_bundle_handle;
      break;
    }

    case PROTON__BUNDLE__CMD_FANS:
    {
      handle = &_cmd_fans_bundle_handle;
      break;
    }

    case PROTON__BUNDLE__DISPLAY_STATUS:
    {
      handle = &_display_status_bundle_handle;
      break;
    }

    case PROTON__BUNDLE__CMD_LIGHTS:
    {
      handle = &_cmd_lights_bundle_handle;
      break;
    }

    case PROTON__BUNDLE__BATTERY:
    {
      handle = &_battery_bundle_handle;
      break;
    }

    case PROTON__BUNDLE__PINOUT_COMMAND:
    {
      handle = &_pinout_command_bundle_handle;
      break;
    }

    case PROTON__BUNDLE__CMD_SHUTDOWN:
    {
      handle = &_cmd_shutdown_bundle_handle;
      break;
    }

    case PROTON__BUNDLE__CMD_SHUTDOWN_RESPONSE:
    {
      handle = &_cmd_shutdown_response_bundle_handle;
      break;
    }

    case PROTON__BUNDLE__CLEAR_NEEDS_RESET:
    {
      handle = &_clear_needs_reset_bundle_handle;
      break;
    }

    case PROTON__BUNDLE__CLEAR_NEEDS_RESET_RESPONSE:
    {
      handle = &_clear_needs_reset_response_bundle_handle;
      break;
    }

    case PROTON_HEARTBEAT_ID:
    {
      switch (producer)
      {
        case PROTON__NODE__PC__ID:
        {
          handle = &_pc_heartbeat_bundle_handle;
          break;
        }

        case PROTON__NODE__MCU__ID:
        {
          handle = &_mcu_heartbeat_bundle_handle;
          break;
        }

        default:
        {
          return PROTON_ERROR;
        }
      }

      break;
    }

    default:
    {
      return PROTON_ERROR;
    }
  }

  // Check that the producer produces this bundle
  if (!(handle->producers & producer))
  {
    return PROTON_ERROR;
  }

  // Decode bundle
  status = proton_decode(handle, buffer, length);
  if (status != PROTON_OK)
  {
    return status;
  }

  return PROTON_OK;
}

