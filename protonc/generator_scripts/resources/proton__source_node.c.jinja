// Bundle Receive Function

proton_status_e proton_node_pc_receive(proton_node_t * node, size_t length)
{
  // Check that the node is not NULL
  if (node == NULL || node->peers == NULL || node->peer_count <= PROTON__PEER__PC)
  {
    return PROTON_NULL_PTR_ERROR;
  }

  uint32_t id;
  proton_callback_t callback;
  proton_status_e status;
  proton_peer_t peer = node->peers[PROTON__PEER__PC];

  // Check that peer mutex functions are not NULL
  if (peer.state == PROTON_NODE_UNCONFIGURED)
  {
    return PROTON_INVALID_STATE_ERROR;
  }

  // Decode bundle
  status = proton_bundle_decode(peer.atomic_buffer.buffer, peer.id, &id, length);

  if (status != PROTON_OK)
  {
    return status;
  }

  switch (id)
  {
    case PROTON__BUNDLE__CMD_FANS:
    {
      callback = proton_bundle_cmd_fans_callback;
      break;
    }

    case PROTON__BUNDLE__DISPLAY_STATUS:
    {
      callback = proton_bundle_display_status_callback;
      break;
    }

    case PROTON__BUNDLE__CMD_LIGHTS:
    {
      callback = proton_bundle_cmd_lights_callback;
      break;
    }

    case PROTON__BUNDLE__BATTERY:
    {
      callback = proton_bundle_battery_callback;
      break;
    }

    case PROTON__BUNDLE__PINOUT_COMMAND:
    {
      callback = proton_bundle_pinout_command_callback;
      break;
    }

    case PROTON__BUNDLE__CMD_SHUTDOWN:
    {
      callback = proton_bundle_cmd_shutdown_callback;
      break;
    }

    case PROTON__BUNDLE__CLEAR_NEEDS_RESET:
    {
      callback = proton_bundle_clear_needs_reset_callback;
      break;
    }

    case PROTON_HEARTBEAT_ID:
    {
      callback = proton_bundle_pc_heartbeat_callback;
      break;
    }

    default:
    {
      return PROTON_ERROR;
    }
  }

  // Execute callback
  if (callback)
  {
    callback(node->context);
  }

  return PROTON_OK;
}

// Bundle Send Function

proton_status_e proton_bundle_send(proton_node_t * node, uint32_t id)
{
  // Check that peers are not NULL
  if (node == NULL || node->peers == NULL)
  {
    return PROTON_NULL_PTR_ERROR;
  }

  // Check that write functions are not NULL
  for (int i = 0; i < node->peer_count; i += 1)
  {
    if (node->peers[i].transport.write == NULL)
    {
      return PROTON_NULL_PTR_ERROR;
    }
  }

  // Check that node is connected
  if (node->state != PROTON_NODE_ACTIVE)
  {
    return PROTON_INVALID_STATE_ERROR;
  }

  proton_bundle_handle_t * handle;
  proton_status_e status;
  size_t bytes_encoded;
  size_t bytes_written;

  // Find correct bundle handle
  switch (id)
  {
    case PROTON__BUNDLE__LOG:
    {
      handle = &_log_bundle_handle;
      break;
    }

    case PROTON__BUNDLE__STATUS:
    {
      handle = &_status_bundle_handle;
      break;
    }

    case PROTON__BUNDLE__POWER:
    {
      handle = &_power_bundle_handle;
      break;
    }

    case PROTON__BUNDLE__EMERGENCY_STOP:
    {
      handle = &_emergency_stop_bundle_handle;
      break;
    }

    case PROTON__BUNDLE__TEMPERATURE:
    {
      handle = &_temperature_bundle_handle;
      break;
    }

    case PROTON__BUNDLE__STOP_STATUS:
    {
      handle = &_stop_status_bundle_handle;
      break;
    }

    case PROTON__BUNDLE__PINOUT_STATE:
    {
      handle = &_pinout_state_bundle_handle;
      break;
    }

    case PROTON__BUNDLE__ALERTS:
    {
      handle = &_alerts_bundle_handle;
      break;
    }

    case PROTON__BUNDLE__CMD_SHUTDOWN_RESPONSE:
    {
      handle = &_cmd_shutdown_response_bundle_handle;
      break;
    }

    case PROTON__BUNDLE__CLEAR_NEEDS_RESET_RESPONSE:
    {
      handle = &_clear_needs_reset_response_bundle_handle;
      break;
    }

    case PROTON_HEARTBEAT_ID:
    {
      handle = &_mcu_heartbeat_bundle_handle;
      break;
    }

    default:
    {
      return PROTON_ERROR;
    }
  }

  status = node->atomic_buffer.lock(node->context);

  if (status == PROTON_OK)
  {
    status = proton_bundle_encode(node->atomic_buffer.buffer, id, &bytes_encoded);

    if (status == PROTON_OK)
    {
      // Send bundle
      for (int i = 0; i < node->peer_count; i += 1)
      {
        // Send to all bundle consumers
        if (handle->consumers & node->peers[i].id)
        {
          proton_status_e write_status = node->peers[i].transport.write(node->context, node->atomic_buffer.buffer.data, bytes_encoded, &bytes_written);
          if (write_status != PROTON_OK)
          {
            status = write_status;
          }
        }
      }
    }

    status = node->atomic_buffer.unlock(node->context);
  }

  return status;
}

